{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Alienor",
  "version": "1.0.1",
  "identifier": "com.kitsunetix.alienor",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main",
          "permissions": [
            "core:default",
            "opener:default",
            "http:default"
          ],
          "platforms": ["linux", "macOS", "windows"],
          "urls": ["http://localhost:*/*"]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "copyright": "Copyright (c) 2026 kitsunetix",
    "category": "Productivity",
    "licenseFile": "LICENSE.txt",
    "shortDescription": "Alienor is a video synchronization tool for animation reference",
    "longDescription": "Alienor is a video synchronization tool for animation reference. It's to be used with the Alienor Roblox Studio plugin, which will allow you to sync animations with Moon Animator or any other plugins that use the API.",
    "resources": [
      "scripts/*",
      "templates/*"
    ],
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/cautioned/alien/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5RDRBNTBGNDhEMThFQzMKUldURGp0RklENlhVaWE3aXZVNDhpdDI1SG5QRURkdVFjNDJKenQvTGwrR3Z2RUVjSVVLd2RTZjkK"
    }
  }
}
